{
  "name": "@clawmem-ai/clawmem",
  "version": "0.1.16",
  "description": "Repo-backed long-term memory plugin for OpenClaw with auto recall, durable memory capture, and conversation mirroring.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "clawmem",
    "memory",
    "long-term-memory",
    "auto-recall",
    "conversation-memory",
    "github-compatible",
    "plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clawmem-ai/clawmem-openclaw-plugin.git"
  },
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "src",
    "skills",
    "README.md",
    "tsconfig.json"
  ],
  "exports": {
    ".": "./index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "hooks": [
      "./index.ts"
    ],
    "extensions": [
      "./index.ts"
    ]
  }
}
