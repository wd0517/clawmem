    "index.ts",
    "openclaw.plugin.json",
    "src",
    "README.md",
    "tsconfig.json"
  ],
  "exports": {
    ".": "./index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
