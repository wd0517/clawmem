{
  "name": "@clawmem-ai/clawmem",
  "version": "0.1.10",
  "description": "Mirror OpenClaw sessions into GitHub-compatible issues and comments.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clawmem-ai/clawmem-openclaw-plugin.git"
  },
